<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.SmartAttendance" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/surface_soft_blue</item>
        <item name="colorOnPrimaryContainer">@color/brand_primary</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/surface_background</item>
        <item name="colorSurface">@color/surface_card</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorSurfaceVariant">@color/surface_background</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:windowLightStatusBar" tools:targetApi="m">false</item>
    </style>
    <style name="Theme.SmartAttendance.NoActionBar" parent="Theme.SmartAttendance">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    <style name="Theme.SmartAttendance.Splash" parent="Theme.SmartAttendance.NoActionBar">
        <item name="android:windowBackground">@color/surface_background</item>
        <item name="android:statusBarColor">@color/surface_background</item>
    </style>
    <style name="Theme.SmartAttendance.Pro" parent="Theme.SmartAttendance">
        <item name="materialButtonStyle">@style/Widget.SmartAttendance.Button</item>
        <item name="materialCardViewStyle">@style/Widget.SmartAttendance.Card</item>
        <item name="textInputStyle">@style/Widget.SmartAttendance.TextInputLayout</item>
    </style>
    <style name="Widget.SmartAttendance.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    <style name="Widget.SmartAttendance.Button.Error" parent="Widget.SmartAttendance.Button">
        <item name="backgroundTint">@color/error_red</item>
        <item name="iconTint">@color/white</item>
    </style>
    <style name="Widget.SmartAttendance.Button.Secondary" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">16dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
    </style>
    <style name="Widget.SmartAttendance.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">28dp</item>
        <item name="cardElevation">3dp</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>
    <style name="Widget.SmartAttendance.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxStrokeColor">@color/brand_primary</item>
        <item name="hintTextColor">@color/brand_primary</item>
        <item name="android:layout_marginBottom">16dp</item>
    </style>
    <style name="ShapeAppearance.SmartAttendance.Circle" parent="">
        <item name="cornerSize">50%</item>
    </style>
    <style name="Theme.SmartAttendance.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />
    <style name="Theme.SmartAttendance.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>
